scroll_following = true

; ── TOAST OVERLAY ──

[node name="ToastAnchor" type="Control" parent="."]
layout_mode = 1
anchors_preset = 10
anchor_right = 1.0
offset_bottom = 80.0
grow_horizontal = 2
mouse_filter = 2

[node name="ToastMargin" type="MarginContainer" parent="ToastAnchor"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 2
theme_override_constants/margin_left = 16
theme_override_constants/margin_top = 12
theme_override_constants/margin_right = 16
theme_override_constants/margin_bottom = 0

[node name="ToastPanel" type="PanelContainer" parent="ToastAnchor/ToastMargin"]
unique_name_in_owner = true
layout_mode = 2
size_flags_vertical = 0
mouse_filter = 2
visible = false
theme_override_styles/panel = SubResource("tst")

[node name="ToastLabel" type="Label" parent="ToastAnchor/ToastMargin/ToastPanel"]
unique_name_in_owner = true
layout_mode = 2
theme_override_colors/font_color = Color(0.0, 0.83, 0.67, 1)
theme_override_font_sizes/font_size = 13
autowrap_mode = 2
